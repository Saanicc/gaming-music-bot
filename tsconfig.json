{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "outDir": "./dist",
    "removeComments": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "paths": {
      "@/root/*": ["./*"],
      "@/*": ["./src/*"],
      "@/ui/*": ["./src/ui/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/services/*": ["./src/services/*"],
      "@/db": ["./src/db/"],
      "@/db/*": ["./src/db/*"],
      "@/api/*": ["./src/api/*"],
      "@/modules/*": ["./src/modules/*"],
      "@/interactions/*": ["./src/interactions/*"]
    }
  }
}
