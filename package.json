{
  "name": "gaming-music-bot",
  "private": true,
  "version": "2.2.9",
  "description": "A Discord bot that plays music",
  "main": "index.js",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup src/index.ts --minify --external unfetch,ffmpeg-static",
    "docker-build": "node docker-scripts.js build",
    "docker-save": "node docker-scripts.js save",
    "build-prod": "npm run build && npm run docker-build && npm run docker-save",
    "release:patch": "npm version patch && git push --follow-tags --atomic origin HEAD",
    "release:minor": "npm version minor && git push --follow-tags --atomic origin HEAD",
    "release:major": "npm version major && git push --follow-tags --atomic origin HEAD"
  },
  "dependencies": {
    "@snazzah/davey": "0.1.10",
    "canvacord": "6.0.4",
    "discord-player": "7.2.0",
    "discord-player-deezer": "2.5.0",
    "discord-player-soundcloud": "1.0.7",
    "discord-player-spotify": "1.1.7",
    "discord-player-youtubei": "3.0.0-beta.4",
    "discord.js": "14.26.1",
    "dotenv": "17.3.1",
    "mediaplex": "1.0.0",
    "mongoose": "8.19.2",
    "youtube-dl-exec": "3.1.3"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/jsdom": "27.0.0",
    "jest": "30.3.0",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
